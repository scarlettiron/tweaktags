{
  "name": "@tweaktags/server",
  "version": "1.0.0",
  "description": "Framework agnostic Node backend handler for TweakTags",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=16"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tweaktags/auth-jwt": "workspace:*",
    "@tweaktags/core": "workspace:*",
    "@tweaktags/db-postgres": "workspace:*"
  },
  "peerDependencies": {
    "@tweaktags/db-mysql": "workspace:*",
    "@tweaktags/db-sqlite": "workspace:*",
    "@tweaktags/storage-s3": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@tweaktags/db-mysql": {
      "optional": true
    },
    "@tweaktags/db-sqlite": {
      "optional": true
    },
    "@tweaktags/storage-s3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "author": "Scarlett A. Scott (codescarlett)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scarlettiron/tweaktags.git",
    "directory": "packages/server"
  },
  "homepage": "https://scarlettiron.github.io/tweaktags",
  "bugs": {
    "url": "https://github.com/scarlettiron/tweaktags/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
