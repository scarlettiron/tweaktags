{
  "name": "@tweaktags/cli",
  "version": "1.0.0",
  "description": "Command line tools for TweakTags, migrate the database and create a superuser",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=16"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tweaktags": "./dist/bin.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tweaktags/core": "workspace:*",
    "@tweaktags/server": "workspace:*",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "author": "Scarlett A. Scott (codescarlett)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scarlettiron/tweaktags.git",
    "directory": "packages/cli"
  },
  "homepage": "https://scarlettiron.github.io/tweaktags",
  "bugs": {
    "url": "https://github.com/scarlettiron/tweaktags/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
