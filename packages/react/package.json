{
  "name": "@tweaktags/react",
  "version": "1.0.0",
  "description": "React provider, Editable component, and hooks for TweakTags",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=16"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tweaktags/browser": "workspace:*",
    "@tweaktags/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "author": "Scarlett A. Scott (codescarlett)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scarlettiron/tweaktags.git",
    "directory": "packages/react"
  },
  "homepage": "https://scarlettiron.github.io/tweaktags",
  "bugs": {
    "url": "https://github.com/scarlettiron/tweaktags/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
