{
  "name": "@tweaktags/db-mysql",
  "version": "1.0.0",
  "description": "MySQL and MariaDB database adapter and migrations for TweakTags",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=16"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tweaktags/core": "workspace:*",
    "mysql2": "^3.11.4"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "author": "Scarlett A. Scott (codescarlett)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scarlettiron/tweaktags.git",
    "directory": "packages/db-mysql"
  },
  "homepage": "https://scarlettiron.github.io/tweaktags",
  "bugs": {
    "url": "https://github.com/scarlettiron/tweaktags/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
